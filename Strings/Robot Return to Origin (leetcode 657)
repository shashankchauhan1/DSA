// java

class Solution {
    public boolean judgeCircle(String moves) {
        int posX = 0, posY = 0;

        for(int i=0; i<moves.length(); i++){
            char ch = moves.charAt(i);
            if(ch == 'U') posY++;
            else if(ch == 'D') posY--;
            else if(ch == 'R') posX++;
            else posX--;
        }

        return posX == 0 && posY == 0;
    }
}
