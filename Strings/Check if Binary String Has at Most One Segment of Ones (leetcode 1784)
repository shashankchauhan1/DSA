// java

class Solution {
    public boolean checkOnesSegment(String s) {
        int cnt = 0;
        boolean found = true;
        for(int i=1; i<s.length(); i++){
            if(s.charAt(i)=='1'){
                found = true;
            }
            else{
                if(found){
                    cnt++;
                    found = false;
                }
            }
        }
        if(found) cnt++;
        return cnt==1;
    }
}
